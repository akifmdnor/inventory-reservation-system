DATABASE_URL="postgresql://inventory:inventory@localhost:5434/inventory_reservation?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3002
NODE_ENV=development
# Default reservation TTL (seconds). Tests may override with RESERVATION_TTL_SECONDS=2.
RESERVATION_TTL_SECONDS=120
# Set to 1 to expose demo reset/race endpoints (recommended only for local).
DEMO_ROUTES_ENABLED=1
