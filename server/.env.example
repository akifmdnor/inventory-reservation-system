# PostgreSQL — use your own DB (local install, cloud, etc.). This compose file does not start Postgres.
# Render / many hosts require TLS, e.g. append: ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Local dev with `npm run dev` (Redis from `npm run db:up`):
REDIS_URL="redis://localhost:6379"

PORT=3002
NODE_ENV=development
RESERVATION_TTL_SECONDS=120
DEMO_ROUTES_ENABLED=1
